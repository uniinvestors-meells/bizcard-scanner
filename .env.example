# --- Card scanning (pick one) ---
# Free tier: https://aistudio.google.com/apikey (default scanner)
GEMINI_API_KEY=

# Optional alternative scanner, only used if GEMINI_API_KEY is not set.
# Pay-per-use API key from https://console.anthropic.com/ (NOT your claude.ai subscription)
ANTHROPIC_API_KEY=

# --- Saving contacts ---
# HubSpot private app token (Settings > Integrations > Private Apps), scopes:
# crm.objects.contacts.read, crm.objects.contacts.write
HUBSPOT_ACCESS_TOKEN=

# Optional: also forward every saved contact to a custom CRM webhook
CUSTOM_CRM_WEBHOOK_URL=
CUSTOM_CRM_API_KEY=

# --- Access control ---
# If set, the app requires this passcode (header x-passcode) to use the API.
# Leave blank for home/local use.
APP_PASSCODE=

# --- Server ---
PORT=3000
